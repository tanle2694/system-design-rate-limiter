{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiter": {
    "Enabled": true,
    "DefaultAlgorithm": "TokenBucket",
    "DefaultLimit": 100,
    "DefaultWindowSeconds": 60,
    "EnableHeaders": true,
    "RulesFile": "rules/rate-limit-rules.yaml"
  },
  "Redis": {
    "Endpoints": ["localhost:6379", "localhost:6380", "localhost:6381"],
    "InstanceName": "rate-limiter",
    "KeyPrefix": "rl:",
    "ConnectTimeout": 5000,
    "SyncTimeout": 5000
  }
}
