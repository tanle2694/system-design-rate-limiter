{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiter": {
    "Enabled": true,
    "DefaultAlgorithm": "TokenBucket",
    "DefaultLimit": 100,
    "DefaultWindowSeconds": 60,
    "EnableHeaders": true,
    "RulesFile": "rules/rate-limit-rules.yaml"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "rate-limiter",
    "KeyPrefix": "rl:"
  }
}
